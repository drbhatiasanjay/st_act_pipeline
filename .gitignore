# Competition data - large, downloaded separately, never belongs in git
/data/
*.zarr/
*.geff/

# Trained model weights (any directory, not just /models/ -- checkpoint_dataset/,
# checkpoints_smoke_test/, kaggle_sanity_outputs/ have all accumulated real .pt
# files this session that /models/-only patterns below missed)
/models/*.pth
/models/*.pt
/models/*.ckpt
/checkpoint_dataset/
/checkpoints_smoke_test/
/kaggle_sanity_outputs/checkpoints_sanity/
/kaggle_sanity_outputs/partial_checkpoint.pt

# Vendored offline install wheels -- regenerable via pip, binary bloat
/wheels_offline/*.whl

# Unrelated separate project accidentally sitting in this directory (Node/TS
# web app, node_modules etc.) -- not part of st_act_pipeline
/stpipelinecode/

# Editor / crash artifacts
.cursor/
bash.exe.stackdump

# Python
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Output artifacts
/output/*.csv
/submissions/*.csv

# Run tracking: caches are large/regenerable, logs are per-machine execution history
/.cache/
/logs/
/kaggle_kernel_output/

# Env / secrets
.env
*.env.local

# OS / editor
.DS_Store
Thumbs.db

# Tool-generated caches
.memsearch/
graphify-out/cache/
